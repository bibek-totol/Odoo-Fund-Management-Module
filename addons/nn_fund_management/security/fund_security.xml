    </record>

    <record id="fund_requisition_company_rule" model="ir.rule">
        <field name="name">Fund Requisition Multi-Company</field>
        <field name="model_id" ref="model_fund_requisition"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="fund_bill_company_rule" model="ir.rule">
        <field name="name">Fund Bill Multi-Company</field>
        <field name="model_id" ref="model_fund_bill"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="fund_transfer_company_rule" model="ir.rule">
        <field name="name">Fund Transfer Multi-Company</field>
        <field name="model_id" ref="model_fund_transfer"/>
