<odoo>
   
    <record id="module_category_nn_fund_management" model="ir.module.category">
        <field name="name">Fund Management</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_fund_user" model="res.groups">
        <field name="name">Fund User</field>
        <field name="category_id" ref="module_category_nn_fund_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_finance_user" model="res.groups">
        <field name="name">Finance User</field>
        <field name="category_id" ref="module_category_nn_fund_management"/>
        <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
    </record>

    <record id="group_gm_approver" model="res.groups">
        <field name="name">GM Approver</field>
        <field name="category_id" ref="module_category_nn_fund_management"/>
        <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
    </record>

    <record id="group_md_approver" model="res.groups">
        <field name="name">MD Approver</field>
        <field name="category_id" ref="module_category_nn_fund_management"/>
        <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
    </record>

    <record id="group_fund_admin" model="res.groups">
        <field name="name">Fund Administrator</field>
        <field name="category_id" ref="module_category_nn_fund_management"/>
        <field name="implied_ids" eval="[(4, ref('group_finance_user')), (4, ref('group_gm_approver')), (4, ref('group_md_approver'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

   
    
    <record id="fund_account_company_rule" model="ir.rule">
        <field name="name">Fund Account Multi-Company</field>
        <field name="model_id" ref="model_fund_account"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="fund_incoming_company_rule" model="ir.rule">
        <field name="name">Fund Incoming Multi-Company</field>
        <field name="model_id" ref="model_fund_incoming"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

