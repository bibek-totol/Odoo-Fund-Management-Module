<odoo>
    <data>
      
        <record id="module_category_nn_fund_management" model="ir.module.category">
            <field name="name">Fund Management</field>
            <field name="description">Helps you manage your funds, allocations, and requisitions.</field>
            <field name="sequence">20</field>
        </record>

        <!-- Privileges (Grouping the Selections) -->
        <record id="privilege_fund_user" model="res.groups.privilege">
            <field name="name">User Access</field>
            <field name="category_id" ref="nn_fund_management.module_category_nn_fund_management"/>
        </record>

        <record id="privilege_fund_finance" model="res.groups.privilege">
            <field name="name">Finance Access</field>
            <field name="category_id" ref="nn_fund_management.module_category_nn_fund_management"/>
        </record>

        <record id="privilege_fund_approver" model="res.groups.privilege">
            <field name="name">Approval Access</field>
            <field name="category_id" ref="nn_fund_management.module_category_nn_fund_management"/>
        </record>

        <record id="privilege_fund_admin" model="res.groups.privilege">
            <field name="name">Administrative Access</field>
            <field name="category_id" ref="nn_fund_management.module_category_nn_fund_management"/>
        </record>

        <!-- Groups with Hierarchy -->
        
        <!-- 1. Base User -->
        <record id="group_fund_user" model="res.groups">
            <field name="name">Fund User</field>
            <field name="privilege_id" ref="nn_fund_management.privilege_fund_user"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- 2. Finance (Implies User) -->
        <record id="group_finance_user" model="res.groups">
            <field name="name">Finance User</field>
            <field name="privilege_id" ref="nn_fund_management.privilege_fund_finance"/>
            <field name="implied_ids" eval="[(4, ref('nn_fund_management.group_fund_user'))]"/>
        </record>

        <!-- 3. GM Approver (Implies User) -->
        <record id="group_gm_approver" model="res.groups">
            <field name="name">GM Approver</field>
            <field name="privilege_id" ref="nn_fund_management.privilege_fund_approver"/>
            <field name="implied_ids" eval="[(4, ref('nn_fund_management.group_fund_user'))]"/>
        </record>

        <!-- 4. MD Approver (Implies GM Approver) -->
        <record id="group_md_approver" model="res.groups">
            <field name="name">MD Approver</field>
            <field name="privilege_id" ref="nn_fund_management.privilege_fund_approver"/>
            <field name="implied_ids" eval="[(4, ref('nn_fund_management.group_gm_approver'))]"/>
        </record>

        <!-- 5. Administrator (Implies both MD and Finance) -->
        <record id="group_fund_admin" model="res.groups">
            <field name="name">Fund Administrator</field>
            <field name="privilege_id" ref="nn_fund_management.privilege_fund_admin"/>
            <field name="implied_ids" eval="[(4, ref('nn_fund_management.group_md_approver')), (4, ref('nn_fund_management.group_finance_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>