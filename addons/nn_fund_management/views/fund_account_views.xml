<odoo>
    <record id="view_fund_account_list" model="ir.ui.view">
        <field name="name">fund.account.list</field>
        <field name="model">fund.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="account_type"/>
                <field name="account_number"/>
                <field name="total_received"/>
                <field name="available_balance"/>
                <field name="held_balance"/>
                <field name="assigned_balance"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_fund_account_form" model="ir.ui.view">
        <field name="name">fund.account.form</field>
        <field name="model">fund.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>

                    <group>
                        <group string="Account Details">
                            <field name="account_type"/>
                            <field name="account_number"/>
                            <field name="currency_id" readonly="1"/>
                        </group>
                        <group string="Company">
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group string="Balance Summary">
                        <group>
                            <field name="total_received" readonly="1"/>
                            <field name="held_balance" readonly="1"/>
                        </group>
                        <group>
                            <field name="available_balance" readonly="1"/>
                            <field name="assigned_balance" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Incoming Funds">
                            <field name="incoming_funds">
                                <list create="false">
                                    <field name="name"/>
                                    <field name="amount"/>
                                    <field name="state"/>
                                    <field name="date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Allocations">
                            <field name="allocation_ids">
                                <list create="false">
                                    <field name="name"/>
                                    <field name="amount"/>
                                    <field name="state"/>
                                    <field name="request_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">fund.account</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
