<odoo>
    <record id="view_fund_bill_list" model="ir.ui.view">
        <field name="name">fund.bill.list</field>
        <field name="model">fund.bill</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-success="state == 'paid'">
                <field name="name"/>
                <field name="requisition_id"/>
                <field name="vendor"/>
                <field name="amount"/>
                <field name="date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_fund_bill_form" model="ir.ui.view">
        <field name="name">fund.bill.form</field>
        <field name="model">fund.bill</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_post" type="object" string="Post"
                        class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_pay" type="object" string="Pay"
                        class="oe_highlight" invisible="state != 'posted'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                        invisible="state not in ('draft','posted','paid')"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,posted,paid,cancelled"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Bill Details">
                            <field name="requisition_id" readonly="state != 'draft'"
                                options="{'no_create': True}"/>
                            <field name="vendor" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                        </group>
                        <group string="Linked Info">
                            <field name="project_id" readonly="1"/>
                            <field name="expense_head_id" readonly="1"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group string="Notes &amp; Attachment">
                        <field name="description" readonly="state != 'draft'"
                            widget="text" nolabel="1"
                            placeholder="Add bill description or payment notes…"/>
                        <field name="attachment" filename="attachment_name"
                            readonly="state != 'draft'" widget="binary"
                            string="Bill Document"/>
                        <field name="attachment_name" invisible="1"/>
                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_fund_bill" model="ir.actions.act_window">
        <field name="name">Bills</field>
        <field name="res_model">fund.bill</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
