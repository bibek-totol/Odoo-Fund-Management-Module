<?xml version="1.0" encoding="utf-8"?>
<odoo>

   
    <record id="view_fund_dashboard_form" model="ir.ui.view">
        <field name="name">fund.dashboard.form</field>
        <field name="model">fund.dashboard</field>
        <field name="arch" type="xml">
            <form string="Fund Management Dashboard" create="false" edit="false" delete="false">

                
                <header>
                    <button name="action_open_dashboard"
                            string="Refresh Dashboard"
                            type="object"
                            class="btn-primary"
                            icon="fa-refresh"/>
                </header>

                <sheet>
                    <field name="currency_id" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                   
                    <div class="row mt16 mb8">
                        <div class="col-12">
                            <h2 class="text-muted">
                                <i class="fa fa-bar-chart mr8"/>Fund Account Summary
                            </h2>
                        </div>
                    </div>

                    <div class="row">
                       
                        <div class="col-lg-2 col-md-4 col-sm-6 mb16">
                            <div class="o_stat_button o_field_widget o_stat_info" style="background:#28a745;color:#fff;border-radius:8px;padding:16px;text-align:center;">
                                <span class="o_stat_value">
                                    <field name="total_received" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                                </span>
                                <span class="o_stat_text">Total Received</span>
                            </div>
                        </div>
                     
                        <div class="col-lg-2 col-md-4 col-sm-6 mb16">
                            <div class="o_stat_button o_field_widget o_stat_info" style="background:#17a2b8;color:#fff;border-radius:8px;padding:16px;text-align:center;">
                                <span class="o_stat_value">
                                    <field name="unassigned_balance" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                                </span>
                                <span class="o_stat_text">Unassigned Balance</span>
                            </div>
                        </div>
                        
                        <div class="col-lg-2 col-md-4 col-sm-6 mb16">
                            <div class="o_stat_button o_field_widget o_stat_info" style="background:#ffc107;color:#212529;border-radius:8px;padding:16px;text-align:center;">
                                <span class="o_stat_value">
                                    <field name="held_amount" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                                </span>
                                <span class="o_stat_text">On Hold</span>
                            </div>
                        </div>
                        
                        <div class="col-lg-2 col-md-4 col-sm-6 mb16">
                            <div class="o_stat_button o_field_widget o_stat_info" style="background:#6f42c1;color:#fff;border-radius:8px;padding:16px;text-align:center;">
                                <span class="o_stat_value">
                                    <field name="assigned_amount" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                                </span>
                                <span class="o_stat_text">Assigned</span>
                            </div>
                        </div>
                        
                        <div class="col-lg-2 col-md-4 col-sm-6 mb16">
                            <div class="o_stat_button o_field_widget o_stat_info" style="background:#dc3545;color:#fff;border-radius:8px;padding:16px;text-align:center;">
                                <span class="o_stat_value">
                                    <field name="total_spent" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                                </span>
                                <span class="o_stat_text">Total Spent</span>
                            </div>
                        </div>
                        
                        <div class="col-lg-2 col-md-4 col-sm-6 mb16">
                            <div class="o_stat_button o_field_widget o_stat_info" style="background:#343a40;color:#fff;border-radius:8px;padding:16px;text-align:center;">
                                <span class="o_stat_value">
                                    <field name="total_pending" readonly="1"/>
                                </span>
                                <span class="o_stat_text">Pending Approvals</span>
                            </div>
                        </div>
                    </div>

                    <div class="row mt8 mb8">
                        <div class="col-12">
                            <h3 class="text-muted">
                                <i class="fa fa-clock-o mr8"/>Pending Approvals Breakdown
                            </h3>
                        </div>
                    </div>
                    <div class="row mb16">
                        <div class="col-md-4">
                            <div class="card text-center p-3 border-warning">
                                <div class="h4 font-weight-bold text-warning">
                                    <field name="pending_allocations" readonly="1"/>
                                </div>
                                <div class="text-muted small">Allocations Pending</div>
                                <button name="%(nn_fund_management.action_fund_allocation)d"
                                        type="action"
                                        string="View Allocations"
                                        class="btn btn-sm btn-outline-warning mt8"/>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card text-center p-3 border-info">
                                <div class="h4 font-weight-bold text-info">
                                    <field name="pending_requisitions" readonly="1"/>
                                </div>
                                <div class="text-muted small">Requisitions Pending</div>
                                <button name="%(nn_fund_management.action_fund_requisition)d"
                                        type="action"
                                        string="View Requisitions"
                                        class="btn btn-sm btn-outline-info mt8"/>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card text-center p-3 border-secondary">
                                <div class="h4 font-weight-bold text-secondary">
                                    <field name="pending_transfers" readonly="1"/>
                                </div>
                                <div class="text-muted small">Transfers Pending</div>
                                <button name="%(nn_fund_management.action_fund_transfer)d"
                                        type="action"
                                        string="View Transfers"
                                        class="btn btn-sm btn-outline-secondary mt8"/>
                            </div>
                        </div>
                    </div>

                   
                    <div class="row mt8 mb8">
                        <div class="col-12">
                            <h3 class="text-muted">
                                <i class="fa fa-folder-open mr8"/>Project Balances
                            </h3>
                        </div>
                    </div>
                    <field name="project_ids" readonly="1" nolabel="1">
                        <list>
                            <field name="name" string="Project"/>
                            <field name="code" string="Code"/>
                            <field name="total_allocated" string="Allocated" widget="monetary"/>
                            <field name="approved_unspent" string="Approved Unspent" widget="monetary"/>
                            <field name="requisition_hold" string="Req. Hold" widget="monetary"/>
                            <field name="transfer_hold" string="Transfer Hold" widget="monetary"/>
                            <field name="available_fund" string="Available" widget="monetary"/>
                            <field name="total_spent" string="Spent" widget="monetary"/>
                        </list>
                    </field>

                   
                    <div class="row mt16 mb8">
                        <div class="col-12">
                            <h3 class="text-muted">
                                <i class="fa fa-tags mr8"/>Expense Head Balances
                            </h3>
                        </div>
                    </div>
                    <field name="expense_head_ids" readonly="1" nolabel="1">
                        <list>
                            <field name="name" string="Expense Head"/>
                            <field name="code" string="Code"/>
                            <field name="total_allocated" string="Allocated" widget="monetary"/>
                            <field name="approved_unspent" string="Approved Unspent" widget="monetary"/>
                            <field name="requisition_hold" string="Req. Hold" widget="monetary"/>
                            <field name="transfer_hold" string="Transfer Hold" widget="monetary"/>
                            <field name="available_fund" string="Available" widget="monetary"/>
                            <field name="total_spent" string="Spent" widget="monetary"/>
                        </list>
                    </field>

                  
                    <div class="row mt16 mb8">
                        <div class="col-12">
                            <h3 class="text-muted">
                                <i class="fa fa-history mr8"/>Recent Fund Movements (last 20)
                            </h3>
                        </div>
                    </div>
                    <field name="recent_movement_ids" readonly="1" nolabel="1">
                        <list>
                            <field name="date" string="Date"/>
                            <field name="document_reference" string="Reference"/>
                            <field name="res_model" string="Document Type"/>
                            <field name="approval_level" string="Action"/>
                            <field name="result" string="Result"
                                   decoration-success="result == 'approved'"
                                   decoration-warning="result == 'submitted'"
                                   decoration-danger="result == 'rejected'"
                                   decoration-muted="result == 'cancelled'"
                                   widget="badge"/>
                            <field name="amount" string="Amount" widget="monetary"/>
                            <field name="approver" string="Action By"/>
                            <field name="comment" string="Comment" optional="hide"/>
                        </list>
                    </field>

                </sheet>
            </form>
        </field>
    </record>

    
    <record id="action_fund_dashboard" model="ir.actions.server">
        <field name="name">Fund Dashboard</field>
        <field name="model_id" ref="nn_fund_management.model_fund_dashboard"/>
        <field name="binding_model_id" ref="nn_fund_management.model_fund_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>

    
    <menuitem id="menu_fund_dashboard"
              name="Dashboard"
              parent="nn_fund_management.menu_fund_root"
              action="action_fund_dashboard"
              sequence="1"
              icon="fa-tachometer"/>

</odoo>
