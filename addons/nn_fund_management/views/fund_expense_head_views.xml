<odoo>
    <record id="view_fund_expense_head_list" model="ir.ui.view">
        <field name="name">fund.expense.head.list</field>
        <field name="model">fund.expense.head</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="total_allocated"/>
                <field name="available_fund"/>
                <field name="total_spent"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_fund_expense_head_form" model="ir.ui.view">
        <field name="name">fund.expense.head.form</field>
        <field name="model">fund.expense.head</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Financial Summary">
                        <field name="total_allocated" readonly="1"/>
                        <field name="available_fund" readonly="1"/>
                        <field name="requisition_hold" readonly="1"/>
                        <field name="transfer_hold" readonly="1"/>
                        <field name="approved_unspent" readonly="1"/>
                        <field name="total_spent" readonly="1"/>
                        <field name="incoming_transfers" readonly="1"/>
                        <field name="outgoing_transfers" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fund_expense_head" model="ir.actions.act_window">
        <field name="name">Expense Heads</field>
        <field name="res_model">fund.expense.head</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
