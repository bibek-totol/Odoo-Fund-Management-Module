<odoo>
    <record id="view_fund_incoming_list" model="ir.ui.view">
        <field name="name">fund.incoming.list</field>
        <field name="model">fund.incoming</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-success="state == 'confirmed'">
                <field name="name"/>
                <field name="fund_account_id"/>
                <field name="amount"/>
                <field name="date"/>
                <field name="transaction_reference"/>
                <field name="source"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_fund_incoming_form" model="ir.ui.view">
        <field name="name">fund.incoming.form</field>
        <field name="model">fund.incoming</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                        class="oe_highlight" invisible="state != 'draft'"
                        groups="nn_fund_management.group_finance_user"/>
                    <button name="action_cancel" type="object" string="Reject / Cancel"
                        invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancel Confirmed"
                        invisible="state != 'confirmed'"
                        groups="nn_fund_management.group_fund_admin"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,confirmed,cancelled"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                   
                    <group>
                        <group string="Fund Details">
                            <field name="fund_account_id"
                                readonly="state != 'draft'"
                                options="{'no_create': True}"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                        </group>
                        <group string="Transaction Info">
                            <field name="transaction_reference"
                                readonly="state != 'draft'"/>
                            <field name="source" readonly="state != 'draft'"
                                string="Sender / Source"/>
                            <field name="company_id"
                                groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group string="Additional Information">
                        <field name="description" readonly="state != 'draft'"
                            widget="text" nolabel="1"
                            placeholder="Add notes or remarks about this incoming fund…"/>
                        <field name="attachment" filename="attachment_name"
                            readonly="state != 'draft'" widget="binary"
                            string="Supporting Document"/>
                        <field name="attachment_name" invisible="1"/>
                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_fund_incoming" model="ir.actions.act_window">
        <field name="name">Incoming Funds</field>
        <field name="res_model">fund.incoming</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
