<odoo>
    <record id="view_fund_project_list" model="ir.ui.view">
        <field name="name">fund.project.list</field>
        <field name="model">fund.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="project_manager_id"/>
                <field name="total_allocated"/>
                <field name="available_fund"/>
                <field name="total_spent"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_fund_project_form" model="ir.ui.view">
        <field name="name">fund.project.form</field>
        <field name="model">fund.project</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open" type="object" string="Start Project" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" type="object" string="Close Project" invisible="state != 'open'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="state != 'draft'"/>
                            <field name="code" readonly="state != 'draft'"/>
                            <field name="project_manager_id" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Financial Summary">
                        <field name="total_allocated" readonly="1"/>
                        <field name="available_fund" readonly="1"/>
                        <field name="requisition_hold" readonly="1"/>
                        <field name="transfer_hold" readonly="1"/>
                        <field name="approved_unspent" readonly="1"/>
                        <field name="total_spent" readonly="1"/>
                        <field name="incoming_transfers" readonly="1"/>
                        <field name="outgoing_transfers" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Allocations">
                            <field name="allocation_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="amount"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fund_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">fund.project</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
