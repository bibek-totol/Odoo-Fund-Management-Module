<odoo>
    <record id="view_fund_requisition_tree" model="ir.ui.view">
        <field name="name">fund.requisition.tree</field>
        <field name="model">fund.requisition</field>
        <field name="arch" type="xml">
            <tree decoration-info="state in ('submitted','gm_approved')"
                  decoration-success="state == 'approved'"
                  decoration-muted="state == 'closed'"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="amount"/>
                <field name="billed_amount"/>
                <field name="remaining_amount"/>
                <field name="state"/>
                <field name="required_date"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_requisition_form" model="ir.ui.view">
        <field name="name">fund.requisition.form</field>
        <field name="model">fund.requisition</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" states="draft"/>
                    <button name="action_gm_approve" type="object" string="GM Approve" class="btn-primary" states="submitted"/>
                    <button name="action_md_approve" type="object" string="MD Approve" class="btn-primary" states="gm_approved"/>
                    <button name="action_close" type="object" string="Close Requisition" class="btn-secondary" states="approved"/>
                    <button name="action_reopen" type="object" string="Reopen" class="btn-secondary" states="closed"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-danger" states="submitted,gm_approved"/>
                    <button name="action_cancel" type="object" string="Cancel" states="draft,submitted,gm_approved"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,gm_approved,approved,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="amount" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="request_date" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="required_date" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        </group>
                        <group>
                            <field name="project_id" attrs="{'readonly': [('state', '!=', 'draft')], 'required': [('expense_head_id', '=', False)]}"/>
                            <field name="expense_head_id" attrs="{'readonly': [('state', '!=', 'draft')], 'required': [('project_id', '=', False)]}"/>
                            <field name="requested_by" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="purpose" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        <field name="attachment" filename="attachment_name" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        <field name="attachment_name" invisible="1"/>
                    </group>
                    <group string="Billing Summary">
                        <field name="billed_amount" readonly="1"/>
                        <field name="released_amount" readonly="1"/>
                        <field name="remaining_amount" readonly="1"/>
                    </group>
                    <group string="Approval Comment">
                        <field name="approval_comment"/>
                    </group>
                    <notebook>
                        <page string="Bills">
                            <field name="bill_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="amount"/>
                                    <field name="vendor"/>
                                    <field name="state"/>
                                    <field name="date"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Approval History">
                            <field name="approval_history_ids">
                                <tree>
                                    <field name="approver"/>
                                    <field name="approval_level"/>
                                    <field name="result"/>
                                    <field name="date"/>
                                    <field name="comment"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_fund_requisition" model="ir.actions.act_window">
        <field name="name">Fund Requisitions</field>
        <field name="res_model">fund.requisition</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>