<odoo>
    <record id="view_fund_transfer_list" model="ir.ui.view">
        <field name="name">fund.transfer.list</field>
        <field name="model">fund.transfer</field>
        <field name="arch" type="xml">
            <list decoration-info="state in ('submitted','gm_approved')"
                  decoration-success="state == 'approved'">
                <field name="name"/>
                <field name="transfer_type"/>
                <field name="amount"/>
                <field name="date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_fund_transfer_form" model="ir.ui.view">
        <field name="name">fund.transfer.form</field>
        <field name="model">fund.transfer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit"
                        class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_gm_approve" type="object" string="GM Approve"
                        class="oe_highlight" invisible="state != 'submitted'"
                        groups="nn_fund_management.group_gm_approver"/>
                    <button name="action_md_approve" type="object" string="MD Approve"
                        class="oe_highlight" invisible="state != 'gm_approved'"
                        groups="nn_fund_management.group_md_approver"/>
                    <button name="action_reject" type="object" string="Reject"
                        invisible="state not in ('submitted','gm_approved')"
                        groups="nn_fund_management.group_gm_approver,nn_fund_management.group_md_approver"/>
                    <button name="action_cancel" type="object" string="Cancel"
                        invisible="state not in ('draft','submitted','gm_approved','approved')"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,submitted,gm_approved,approved"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Transfer Details">
                            <field name="transfer_type" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                        </group>
                        <group string="Dates">
                            <field name="request_date" readonly="1"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group string="Source &amp; Destination">
                        <group string="From">
                            <field name="from_project_id"
                                invisible="transfer_type not in ('project', 'mixed_pe')"
                                required="transfer_type in ('project', 'mixed_pe')"
                                readonly="state != 'draft'"/>
                            <field name="from_expense_head_id"
                                invisible="transfer_type not in ('expense', 'mixed_ep')"
                                required="transfer_type in ('expense', 'mixed_ep')"
                                readonly="state != 'draft'"/>
                        </group>
                        <group string="To">
                            <field name="to_project_id"
                                invisible="transfer_type not in ('project', 'mixed_ep')"
                                required="transfer_type in ('project', 'mixed_ep')"
                                readonly="state != 'draft'"/>
                            <field name="to_expense_head_id"
                                invisible="transfer_type not in ('expense', 'mixed_pe')"
                                required="transfer_type in ('expense', 'mixed_pe')"
                                readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group string="Reason &amp; Attachment">
                        <field name="reason" readonly="state != 'draft'"
                            widget="text" nolabel="1"
                            placeholder="Explain why this transfer is needed…"/>
                        <field name="attachment" filename="attachment_name"
                            readonly="state != 'draft'" widget="binary"
                            string="Supporting Document"/>
                        <field name="attachment_name" invisible="1"/>
                        <field name="approval_comment"
                            placeholder="Leave a comment before approving or rejecting…"/>
                    </group>

                    <notebook>
                        <page string="Approval History">
                            <field name="approval_history_ids">
                                <list create="false" edit="false" delete="false">
                                    <field name="approver"/>
                                    <field name="approval_level"/>
                                    <field name="result"/>
                                    <field name="date"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_fund_transfer" model="ir.actions.act_window">
        <field name="name">Fund Transfers</field>
        <field name="res_model">fund.transfer</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
